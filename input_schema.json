{
    "title": "Elite Grant Finder Pro",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
        "grantNiche": {
            "title": "Target Niche",
            "type": "string",
            "description": "Example: Minority Women Entrepreneurs, Rural Education, Solar Energy",
            "editor": "textfield",
            "prefill": "Small Business Grants"
        },
        "maxResults": {
            "title": "Number of Leads",
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
        }
    },
    "required": ["grantNiche"]
}
